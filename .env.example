# ─────────────────────────────────────────────────────────────
# Neural Chat — model endpoints (both OpenAI-compatible)
# ─────────────────────────────────────────────────────────────

# HERMES = orchestrator brain (small, fast, tool-calling).
# Self-host:  vllm serve NousResearch/Hermes-4-Llama-3.1-70B \
#               --tool-call-parser hermes --served-model-name hermes
# or point at any OpenAI-compatible host.
HERMES_BASE_URL=http://localhost:8000/v1
HERMES_API_KEY=sk-local
HERMES_MODEL=hermes

# INKLING = multimodal + heavy-reasoning specialist (975B).
# Self-host:  vllm serve thinkingmachines/Inkling \
#               --tensor-parallel-size 8 --served-model-name inkling
# or a hosted provider (Together / Fireworks / Modal / Baseten / HF router).
INKLING_BASE_URL=http://localhost:8001/v1
INKLING_API_KEY=sk-local
INKLING_MODEL=inkling

# Inkling AUDIO endpoint. Hosted routers may not expose audio yet, so this is
# split out — point it at a self-hosted Inkling (native multimodal) if needed.
# Falls back to INKLING_BASE_URL when unset.
INKLING_AUDIO_BASE_URL=
INKLING_AUDIO_API_KEY=
